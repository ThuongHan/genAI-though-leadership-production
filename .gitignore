# ── API keys & secrets ──────────────────────────────────────────
# Global secrets folder (created to centralise all keys)
backend/secrets/

# Legacy per-component secret locations (kept until migration is done)
backend/Generator/secrets/
backend/Interpreter/.env
backend/Scanner/main_scanner/.env

# Any stray .env files anywhere in the tree
.env
.env.local
.env.*.local
**/*.env

